@model List<PHXCOM.PlatformSDK.Models.Category>
@{
    ViewData["Title"] = "Catalog";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row wrapper-catelog">
        <div class="col-12 mt-4 pt-3">
            <h1 class="page-header">Catalog</h1>
        </div>
        <div class="col-12 mt-5">
            <div class="row">
                @if (Model != null)
                {
                    @await Html.PartialAsync("CategoryListView", Model)
                }
            </div>
        </div>
    </div>
</div>
@await Html.PartialAsync("~/Views/Product/CommonPopupView.cshtml")

@section Scripts
{
    <script type="text/javascript">
        $(document).ready(function () {
            setCookieValuesToAppProp();
        });
    </script>
}