@model PHXCOM.PlatformSDK.Models.Product
@{
    string metaTitle = "";
    string metaDescription = "";
    string metakeyWords = "";
    string metaRobots = "";
    bool isSalePriceAvailable = false;

    decimal? price = Model.Items.FirstOrDefault().Pricing.FirstOrDefault().Price;
    decimal? salePrice = 0;

    var tempProp = Model.Items.FirstOrDefault().Pricing.Where(x => x.IsOnSale ?? true && x.SaleStartDate <= DateTime.Now && (x.SaleEndDate == null || x.SaleEndDate > DateTime.Now)).FirstOrDefault();
    if (tempProp != null)
    {
        salePrice = Model.Items.FirstOrDefault().Pricing.Where(x => x.IsOnSale ?? true && x.SaleStartDate <= DateTime.Now && (x.SaleEndDate == null || x.SaleEndDate > DateTime.Now)).Select(o => o.SalePrice).First();
        isSalePriceAvailable = true;
    }


    int modifiersCount = 0;
    if (Model.Modifiers != null && Model.Modifiers.Count > 0) modifiersCount = Model.Modifiers.Count;


    if (Model.ProductMetaData != null && Model.ProductMetaData.Count > 0)
    {
        if (!string.IsNullOrEmpty(Model.ProductMetaData[0].MetaTitle))
        {
            ViewData["Title"] = Model.ProductMetaData[0].MetaTitle;
        }
        else
        {
            ViewData["Title"] = Model.ProductName;
        }

        metaTitle = Model.ProductMetaData[0].MetaTitle;
        metaDescription = string.IsNullOrEmpty(Model.ProductMetaData[0].MetaDescription) ? "" : Model.ProductMetaData[0].MetaDescription;
        metakeyWords = string.IsNullOrEmpty(Model.ProductMetaData[0].MetaKeywords) ? "" : Model.ProductMetaData[0].MetaKeywords;
        metaRobots = string.IsNullOrEmpty(Model.ProductMetaData[0].MetaRobots) ? "" : Model.ProductMetaData[0].MetaRobots;
    }


    ViewData["Description"] = metaDescription;
    ViewData["Keywords"] = metakeyWords;
    ViewData["Robots"] = (metaRobots == null ? "" : metaRobots);

    Layout = "~/Views/Shared/_Layout.cshtml";
    //List<string> breadCrumbs = ViewBag.breadCrumbs;
    Dictionary<string, string> breadCrumbs = ViewBag.breadCrumbs;
    string colourPickerVisibility = "";



    bool hasQty = true;
    int qtyMultiplier = 1;
    int defaultQTY = 1;
    int maxQTY = 10;
    int minQty = 0;
}


