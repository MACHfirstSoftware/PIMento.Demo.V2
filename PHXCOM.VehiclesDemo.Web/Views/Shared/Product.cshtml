                    <table class="table table-bordred table-striped tbl-select-chkbox-align general-template" id="tbProductItem">
                        <thead>
                            <tr class="mobile-tr">
                                <th scope="col" class="col_4 item-number">Item Number</th>
                                <th scope="col" class="col_0 description">Description</th>
                                <th scope="col" class="col_4 text-right price">Price</th>
                                <th scope="col" class="col_4 text-md-right quantity">Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Items != null)
                            {
                                var itemno = 0;
                                if (Model.Items.Count == 1)
                                {
                                    minQty = 1;
                                }
                                foreach (var item in Model.Items)
                                {

                                    <tr>
                                        <td data-label="Item Number : &nbsp;">@item.ItemNumber</td>
                                        <td data-label="Description : &nbsp;">@item.ItemDetails</td>


                                        @if (isSalePriceAvailable)
                                        {
                                            <td data-label="Price : &nbsp;" class="text-right">
                                                <span class="w-100 d-inline-block text-decoration-line-through">@(price.Value.ToString("C") + "/" + item.Units)</span>
                                                <span class="w-100 d-inline-block" id="salePrice1">@(salePrice.Value.ToString("C") + "/" + item.Units)</span>

                                            </td>
                                        }
                                        else
                                        {
                                            <td data-label="Price : &nbsp;" class="text-right" id="regularPrice1">@(price.Value.ToString("C") + "/" + item.Units)</td>
                                        }

                                        @if (item.IsObsolete)
                                        {
                                            <td class="quantity item-input text-right float-lg-left" data-label="Quantity: &nbsp;">
                                                <div class="float-right">
                                                    Discontinued
                                                </div>
                                            </td>
                                        }
                                        else
                                        {
                                            <td class="quantity item-input text-right" data-label="Quantity: &nbsp;">
                                                <div class="float-right ml-3 quantity-new-update">
                                                    @{
                                                        hasQty = true;
                                                        item.MaxQuantity = item.MaxQuantity == 0 ? 100 : item.MaxQuantity;

                                                        if (!item.CalculateInventory)
                                                        {
                                                            hasQty = true;
                                                        }
                                                        else if (item.CalculateInventory)
                                                        {
                                                            if (item.QuantityInStock > 0 && item.MaxQuantity >= item.QuantityInStock)
                                                            {
                                                                item.MaxQuantity = item.QuantityInStock ?? 0;
                                                            }
                                                            else if (item.NextRestockDate != null || item.QuantityInStock == 0)
                                                            {
                                                                hasQty = false;
                                                            }
                                                        }

                                                        if (hasQty)
                                                        {
                                                            itemno++;
                                                            qtyMultiplier = item.QtyMultiplier == 0 ? 1 : item.QtyMultiplier.GetValueOrDefault();
                                                            if (itemno > 1)
                                                            {
                                                                defaultQTY = 0;
                                                            }
                                                            else
                                                            {
                                                                defaultQTY = item.MinQuantity == 0 ? 1 : item.MinQuantity.GetValueOrDefault();
                                                            }
                                                            maxQTY = item.MaxQuantity.GetValueOrDefault();

                                                            int qtySelectorValue = 0;
                                                            if (!item.CalculateInventory || item.QuantityInStock != 0)
                                                            {
                                                                for (var i = defaultQTY; i <= maxQTY; i++)
                                                                {
                                                                    if (qtyMultiplier == 1)
                                                                    {
                                                                        qtySelectorValue = i;
                                                                    }
                                                                    else if (i % qtyMultiplier == 0)
                                                                    {
                                                                        qtySelectorValue = i;
                                                                    }
                                                                }
                                                                <input type="number" class="buttons-only qty-collector w-58 px-2 text-center float-left" id="qty_@item.ItemId" skuId="@item.ItemId" value="@defaultQTY" min="@minQty" max="@qtySelectorValue" maxQty="@qtySelectorValue" style="display: none;" />
                                                            }
                                                        }
                                                        else
                                                        {
                                                            if (string.IsNullOrEmpty(item.InventoryMessage))
                                                            {
                                                                <label>Out of stock</label>
                                                            }
                                                            else
                                                            {
                                                                <label>@item.InventoryMessage</label>
                                                            }
                                                        }
                                                    }
                                                </div>
                                            </td>
                                        }
                                        @*<td class="quantity item-input text-right" data-label="Quantity: &nbsp;">
                                                <input class="qty-collector w-100 px-2 text-right ml-2 ml-md-0" type="text" min="0" max="999" id="qty_@item.ItemId" skuId="@item.ItemId" value="0" />
                                                    <span onclick="orderEntry.qtyHandler(@item.ItemNumber,-1)"><i class="far fa-minus-square font-weight-bold cursor-pointer"></i></span>
                                                    <span onclick="orderEntry.qtyHandler(@item.ItemNumber,1)"><i class="far fa-plus-square font-weight-bold cursor-pointer"></i></span>
                                                <div class="float-right">
                                                    <span onclick="orderEntry.qtyHandler(@item.ItemId,-1)" class="float-left minus-btn"><i class="far fa-minus font-weight-bold cursor-pointer"></i></span>
                                                    <input class="qty-collector w-58 px-2 text-center float-left" type="text" onkeyup="" min="0" max="999" id="qty_@item.ItemId" skuId="@item.ItemId" value="0" />
                                                    <span onclick="orderEntry.qtyHandler(@item.ItemId,1)" class="plus-btn float-left"><i class="far fa-plus font-weight-bold cursor-pointer"></i></span>
