@section scripts {

    <script type="text/javascript">
        $(".quote .filters").addClass("d-none");

        $('.cart-cycle .owl-carousel').owlCarousel({
            margin: 10,
            nav: true,
            responsive: {
                0: {
                    items: 1
                },
                600: {
                    items: 3
                },
                1000: {
                    items: 4
                }
            }
        })
        $('.accessories-cycle .owl-carousel').owlCarousel({
            margin: 25,
            nav: true,
            responsive: {
                0: {
                    items: 1
                },
                700: {
                    items: 2
                },
                900: {
                    items: 3
                },
                1000: {
                    items: 4
                },
                1300: {
                    items: 5
                }
            }
        })

        
    </script>
}
