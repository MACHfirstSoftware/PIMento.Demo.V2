
@{
    ViewData["Title"] = "ForgetPassword";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row wrapper-catelog mb-3 col-lg-5 col-md-8 col-sm-10 col-12 justify-content-center mx-auto">
    <div class="col-12 mt-4 py-3">
        <h1 class="page-header text-center">Reset Password</h1>
        <p > Please enter your e-mail address below and we will send password reset link to you email.</p>
        <p></p>
    </div>
    <div class="col-12 mt-md-1 mt-4">
        <div class="row">
            <form id="frmResetPasswordLink" class="col-12">
                <div class="col-12 float-left  form-group">
                    <label>Email</label>
                    <input type="text" required id="txtEmail" name="txtEmail" placeholder="Email" class="form-control" />
                </div>
                <div class="clearfix"></div>
            </form>

            <div class="col-10 mt-md-4 text-md-left text-center mx-auto">

                <button type="button" class="btn btn-primary common-button w-100 enterHandler" onclick="account.sendResetPasswordLink()">Send Email</button>
            </div>
        </div>
    </div>
</div>




