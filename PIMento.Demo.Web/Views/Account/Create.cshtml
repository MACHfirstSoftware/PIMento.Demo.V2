
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row wrapper-catelog mb-3 col-xl-5 col-lg-6 col-md-8 col-12  justify-content-center mx-auto">
    <div class="col-12 mt-4 py-3">
        <h1 class="page-header text-center">Create Account</h1>
    </div>
    <div class="col-12 mt-md-1 mt-4">
        <div class="row">
            <form id="frmCreateLogin" class="col-12">
                <div class="col-12 float-left  form-group">
                    <label>First Name</label>
                    <input type="text" required id="txtFirstName" name="txtFirstName" placeholder="First Name" class="form-control" />
                </div>
                <div class="clearfix"></div>
                <div class="col-12 float-left form-group">
                    <label>Last Name</label>
                    <input type="text" required id="txtLastName" name="txtLastName" placeholder="Last Name" class="form-control" />
                </div>
                <div class="clearfix"></div>
                <div class="col-12 float-left form-group">
                    <label>Email</label>
                    <input type="text" required id="txtUserName" name="txtUserName" placeholder="Email" class="form-control" />
                </div>
                <div class="clearfix"></div>
                <div class="col-12 float-left form-group">
                    <label>Password</label>
                    <input type="password" required id="txtPsswrd" name="txtPsswrd" placeholder="Password" class="form-control" />
                </div>

                <div class="col-12 float-left form-group">
                    <label>Confirm Password</label>
                    <input type="password" required id="txtPsswrdCnfrm" name="txtPsswrdCnfrm" placeholder="Confirm Password" class="form-control" />
                </div>

            </form>

            <div class="col-10 text-md-left text-center mx-auto mt-4">

                <button type="button" class="btn btn-primary common-button w-100 enterHandler" onclick="account.create()">Create Account</button>
            </div>



        </div>
    </div>
</div>

