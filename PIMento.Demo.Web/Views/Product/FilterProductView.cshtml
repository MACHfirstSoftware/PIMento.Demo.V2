
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "FilterProducts";
}
    <div class="container">
        <div class="custormize-text py-4">
            <span class="float-right" id="customizedApplicationFilterReset" onclick="resetCustomization()" style="display: none"> | <i class="fa fa-times fa-lg" aria-hidden="true"></i></span>
            <label class="float-right mr-2 mb-0" id="lbcustomizeApplicationName"> </label>
        </div>
        <div class="clearfix"></div>
        <hr/>
        <div class="row wrapper-catelog mb-3"> </div>
    </div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/content.js"></script>
<script type="text/javascript">
    $(document).ready(function () {

        let queryString = window.location.search;
        let urlParams = new URLSearchParams(queryString);
        let year = urlParams.get('year');
        let make = urlParams.get('make');
        let model = urlParams.get('model');

        reloadWithCustomization(year, make, model);

    });

</script>
