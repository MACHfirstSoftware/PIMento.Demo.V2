
@model List<PHXCOM.PlatformSDK.Models.Category>
@{
    //Layout = null;
}

@if (Model.Count > 0)
{
    foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-3 col-12 list-item mb-1 text-center pb-md-3 pb-5 mt-2 mt-md-0 d-inline-block float-left image-description-list">
            <a href="/@item.Slug" class="d-inline-block">
                @*<h2 class="image-description-top">@Html.Raw(item.Description)</h2>*@
                <div class="wrapper-image">
                    @if (item.Image != null)
                    {
                        <img src="@item.Image" />
                    }
                    else
                    {
                        <img src="~/images/no-image.png" class="no-image" />
                    }
                </div>
                <h2 class="image-description-title">@item.CategoryName</h2>
                @*<h2 class="image-description-bottom">@Html.Raw(item.AltDescription)</h2>*@
            </a>
        </div>
    }
    @*<h2 class="image-description-bottom">@Html.Raw(Model.AltDescription)</h2>*@
}

