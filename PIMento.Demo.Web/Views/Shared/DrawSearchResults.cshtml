@model List<PHXCOM.PlatformSDK.Models.SearchResult>
@{ 
    var searchKey = ViewBag.Key;
}

    <div class="container">
        <div class="col-12 mt-4 pt-3">
            <h1 class="page-header text-left w-100 d-inline-block"><span class="float-left">@string.Format("Search Results For '{0}'", searchKey) </span> <a href="/" class="pl-4 remove-filter float-right float-lg-left"><i class="far fa-times-circle mr-1"></i> Clear Search Results</a></h1>
        </div>
        <div class="mt-3 mb-5 d-inline-block w-100">
            @if (Model != null && Model.Count > 0)
            {
                foreach (var item in Model[0].SearchResultContent)
                {

                    <div class="col-md-6 col-lg-3 col-12 list-item mb-1 text-center pb-md-3 pb-5 mt-2 mt-md-0 d-inline-block float-left">
                        <a href="/@item.slug" class="d-inline-block">
                            <div class="wrapper-image">
                                @if (item.image != null)
                                {
                                    <img src="@item.image" class="w-100" />
                                }
                                else
                                {
                                    <img src="~/images/no-image.png" class="no-image w-100" />
                                }
                            </div>
                            <h2 class="mt-5 mt-md-0">@item.objectName</h2>
                        </a>
                    </div>

                }

            }
            else
            {
                <h4 class="d-inline-block w-100 content-empty-message no-product-msg"> Sorry. No search results for "@ViewBag.Key".</h4>
                <div class="text-center w-100 d-inline-block mt-4 pt-2 pb-1">
                    <a href="/Golf-Cart-Parts-Accessories" class="common-orange-button px-4"><i class="fas fa-list-ul"></i> Shop All</a>
                </div>
            }
        </div>
    </div>

