@model PHXCOM.PlatformSDK.Models.Category
@{
    var activeNav = "";
    string metaTitle = "";
    string metaDescription = "";
    string metakeyWords = "";
    string metaRobots = "";
    List<PHXCOM.PlatformSDK.Models.ProductCategorySearch> filterCategoryList = ViewBag.FilterCategoryList;
    if (Model.CategoryMetaData != null && Model.CategoryMetaData.Count > 0)
    {
        if (!string.IsNullOrEmpty(Model.CategoryMetaData[0].MetaTitle))
        {
            ViewData["Title"] = Model.CategoryMetaData[0].MetaTitle;
        }
        else
        {
            ViewData["Title"] = Model.CategoryName;
        }

        metaTitle = Model.CategoryMetaData[0].MetaTitle;
        metaDescription = string.IsNullOrEmpty(Model.CategoryMetaData[0].MetaDescription) ? "" : Model.CategoryMetaData[0].MetaDescription;
        metakeyWords = string.IsNullOrEmpty(Model.CategoryMetaData[0].MetaKeywords) ? "" : Model.CategoryMetaData[0].MetaKeywords;
        metaRobots = string.IsNullOrEmpty(Model.CategoryMetaData[0].MetaRobots) ? "" : Model.CategoryMetaData[0].MetaRobots;
    }



    ViewData["Description"] = metaDescription;
    ViewData["Keywords"] = metakeyWords;
    ViewData["Robots"] = metaRobots;

    Layout = "~/Views/Shared/_Layout.cshtml";
    Dictionary<string, string> breadCrumbs = ViewBag.breadCrumbs;
    KeyValuePair<string, string> topBreadCrumbElement = new KeyValuePair<string, string>();
    //if (breadCrumbs.Count > 0)
    //{
    //    topBreadCrumbElement = breadCrumbs.LastOrDefault();
    //}
    var redirectSlug = "";
    if (breadCrumbs.Count > 0)
    {
        KeyValuePair<string, string> lastBreadCrumbElement = breadCrumbs.FirstOrDefault();
        topBreadCrumbElement = breadCrumbs.LastOrDefault();
        redirectSlug = string.Format("/{0}", lastBreadCrumbElement.Key);
    }
    else
    {
        redirectSlug = "/";
    }

    var currentPage = Model.CategoryName;
    if (currentPage == "Inventory")
    {
        activeNav = "inventory";
    }
    else if (currentPage == "Parts & Accessories")
    {
        activeNav = "accessories";
    }

    var displayResultsMessage = "";
    @if (breadCrumbs.Count > 0 && !string.IsNullOrEmpty(topBreadCrumbElement.Value))
    {
        if (topBreadCrumbElement.Value.ToLower() == "inventory")
        {
            displayResultsMessage = "Showing Inventories for your {0} {1} {2}";
        }
        else if (topBreadCrumbElement.Value.ToLower() == "parts & accessories")
        {
            displayResultsMessage = "Showing Parts & Accessories for your {0} {1} {2}";
        }
    }
    else
    {
        displayResultsMessage = "Showing Applications for your {0} {1} {2}";
    }

    var currentAppContent = ViewBag.CurrentAppContent;

}
<input type="hidden" id="isFilter" value="" />
<input type="hidden" id="hdnCurrentCategoryId" value="@Model.CategoryId" />
<input type="hidden" id="hdnCurrentCategoryName" value="@Model.CategoryName" />
<input type="hidden" id="hdnCurrentNavName" value="@activeNav" />
@*<input type="hidden" id="hdnisProductUniversal" value="@Model.IsUniversal" />*@

@*<div id="syndicationBreadcrumbContainer" class="breadcrumbs">
        <div class="container">
            @await Html.PartialAsync("BreadCrumbView", breadCrumbs)
        </div>
    </div>*@

@*@if (filterCategoryList.Count == 0)
    {
        <div id="syndicationBreadcrumbContainer" class="breadcrumbs">
            <div class="container">
                @await Html.PartialAsync("BreadCrumbView", breadCrumbs)
            </div>
        </div>
    }*@

@if (filterCategoryList.Count > 0 && Model.Products == null)
{
    <div class="wrapper-catelog">
        <div class="container">
            <div class="col-12 mt-4 pt-3">
                <h1 class="page-header text-left w-100 d-inline-block"><span class="float-left">@string.Format(displayResultsMessage, currentAppContent.Year, currentAppContent.Make, currentAppContent.Model)</span> <a href="@redirectSlug" onclick="return removeFilter()" class="pl-4 remove-filter float-right float-lg-left"><i class="far fa-times-circle mr-1"></i> Remove Filter</a></h1>
            </div>
            <div class="mt-3 mb-5 d-inline-block w-100">
                @if (breadCrumbs.Count > 0 && !string.IsNullOrEmpty(topBreadCrumbElement.Value))
                {
                    filterCategoryList = filterCategoryList.Where(c => c.TopCategoryName.ToLower() == topBreadCrumbElement.Value.ToLower()).ToList();
                }

                @if (filterCategoryList.Count > 0)
                {

                    @foreach (var item in filterCategoryList)
                    {
                        <div class="col-md-6 col-lg-3 col-12 list-item mb-1 text-center pb-md-3 pb-5 mt-2 mt-md-0 d-inline-block float-left">
                            <a href="/@item.Slug" class="d-inline-block">
                                <div class="wrapper-image">
                                    @if (item.Image != null)
                                    {
                                        <img src="@item.Image" class="w-100" />
                                    }
                                    else
                                    {
                                        <img src="~/images/no-image.png" class="no-image w-100" />
                                    }
                                </div>
                                <h2 class="mt-5 mt-md-0">@item.CategoryName</h2>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <h4 class="d-inline-block w-100 content-empty-message no-product-msg"> Sorry. We do not have products that fit this vehicle.</h4>
                }

            </div>
        </div>
    </div>
}
else
{
    <div id="syndicationBreadcrumbContainer" class="breadcrumbs">
        <div class="container">
            @await Html.PartialAsync("BreadCrumbView", breadCrumbs)
        </div>
    </div>
    <div class="container">
        <div class="row wrapper-catelog mb-3">
            <div class="col-12 mt-2">
                <h1 class="page-header text-center text-md-left">@Html.Raw(Model.Description)</h1>
            </div>
            <div class="col-12 mt-md-3 mt-4">
                <div class=" form-group mb-0 text-center text-md-left font-family-oswald-light">

                    @*<h2 class="image-description-top">@Html.Raw(Model.Description)</h2>*@

                    @if (Model.SubCategories != null)
                    {
                        @await Html.PartialAsync("CategoryListView", Model.SubCategories)

                    }
                </div>
            </div>

            <div class="col-12 mt-md-3 mt-4">
                <div class="row">
                    @if (Model.Products != null)
                    {
                        @await Html.PartialAsync("ProductListView", Model.Products)
                    }
                </div>
            </div>
            <h1 class="page-header text-center text-md-left w-100"><p> @Html.Raw(Model.AltDescription)</p></h1>
        </div>
    </div>
}
@await Html.PartialAsync("~/Views/Product/CommonPopupView.cshtml")

@section Scripts
{
    <script type="text/javascript">
        $(document).ready(function () {
            setCookieValuesToAppProp();
        });
    </script>
}